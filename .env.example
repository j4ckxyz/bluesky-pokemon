# Required: Bluesky login
BLUESKY_IDENTIFIER=your.handle.or.email
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: custom PDS service (defaults to https://bsky.social)
# BLUESKY_SERVICE_URL=https://bsky.social

# Optional: display title used in posts (default: Pokemon Red)
# GAME_TITLE=Pokemon Red

# Optional: ROM path (defaults to ./roms/pokemon-red.gb)
# ROM_PATH=./roms/pokemon-red.gb

# Optional: save basename (defaults to ROM filename without extension)
# SAVE_BASENAME=pokemon-red

# Optional storage locations (defaults shown)
# DATA_DIR=./data
# SAVE_PATH=./data/pokemon-red.sav
# STATE_PATH=./data/bot-state.json
# LATEST_FRAME_PATH=./data/latest-scene.png
# SAVE_BACKUP_DIR=./data/save-backups

# Real-time turn behavior
# Poll for replies every N seconds
# POLL_INTERVAL_SECONDS=20
# If no valid replies and scene stays static this long, auto-skip loading/idle frames
# IDLE_AUTO_SKIP_SECONDS=45
# Wait at least this long after scene post before resolving any move
# MIN_TURN_SECONDS=30
# After first valid reply, wait this long to collect more votes
# SETTLE_AFTER_FIRST_REPLY_SECONDS=20
# If no valid replies by this time, post a reminder repost
# MAX_TURN_MINUTES=15

# Optional save cadence
# SAVE_INTERVAL_MINUTES=60
# SAVE_BACKUP_KEEP=168

# Optional emulator stepping
# FRAMES_PER_TURN=120
# BUTTON_HOLD_FRAMES=3
# INITIAL_WARMUP_FRAMES=24
# Auto-skip static/loading scenes after a chosen move
# AUTO_SKIP_STATIC_SCREENS=true
# AUTO_SKIP_MAX_FRAMES=900
# AUTO_SKIP_STEP_FRAMES=120

# Optional post settings
# POST_LANGS=en
# Sent as hidden Bluesky tags (outline hashtags), not visible hashtag text
# POST_HASHTAGS=PokemonRed,BlueskyPlaysGameBoy,GameBoy

# Optional anti-spam behavior
# false = keep one reminder repost active until a valid vote arrives
# true  = repost reminder every cycle once MAX_TURN_MINUTES is exceeded
# REPOST_EVERY_TICK=false

# Optional local dry-run mode (no Bluesky writes)
# DRY_RUN=false
